def extract_keywords(df):

    text = " ".join(df["댓글"].astype(str))

    words = re.findall(
        r"[가-힣]{2,}",
        text
    )

    stopwords = {

        "정말","진짜","너무","그리고","입니다",
        "영상","오늘","그냥","항상","감사",
        "이번","이거","저는","제가","ㅋㅋ","ㅎㅎ",
        "있어요","합니다","같아요","입니다",
        "이렇게","하세요","입니다","진심"
    }

    words = [

        w

        for w in words

        if w not in stopwords

    ]

    counter = Counter(words)

    return counter.most_common(20)


######################################################
# 워드클라우드
######################################################

def draw_wordcloud(df):

    text = " ".join(df["댓글"])

    words = re.findall(
        r"[가-힣]{2,}",
        text
    )

    text = " ".join(words)

    wc = WordCloud(

        font_path="NanumGothic.ttf",

        width=1200,

        height=700,

        background_color="white"

    ).generate(text)

    fig, ax = plt.subplots(figsize=(12,6))

    ax.imshow(wc)

    ax.axis("off")

    st.pyplot(fig)


