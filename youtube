# 감성 분석 모델
######################################################

@st.cache_resource
def load_sentiment_model():

    classifier = pipeline(
        "text-classification",
        model="snunlp/KR-FinBert-SC"
    )

    return classifier


######################################################
# 감성 분석
######################################################

def analyze_sentiment(df):

    classifier = load_sentiment_model()

    sentiments = []
    scores = []

    progress = st.progress(0)

    total = len(df)

    for i, text in enumerate(df["댓글"]):

        try:

            result = classifier(
                text[:512]
            )[0]

            label = result["label"]

            score = result["score"]

        except:

            label = "중립"
            score = 0

        sentiments.append(label)
        scores.append(score)

        progress.progress((i+1)/total)

    progress.empty()

    df["감성"] = sentiments
    df["신뢰도"] = scores

    return df


